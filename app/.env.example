# ===== Google Credentials =====
# Choose ONE of the following methods:

# Method 1: Service Account JSON file (recommended for local development)
GOOGLE_CREDENTIALS_FILE=./credentials.json

# Method 2: Base64-encoded JSON (recommended for cloud deployment)
# GOOGLE_CREDENTIALS_BASE64=your_base64_encoded_credentials

# Method 3: Raw JSON string
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"..."}'

# ===== Google Sheets =====
# Your Google Spreadsheet ID (from the URL)
# Example: https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ===== CORS =====
# Allowed origins for the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# ===== Frontend =====
# Backend API URL (for the frontend to connect to)
VITE_API_URL=http://localhost:8000/api
